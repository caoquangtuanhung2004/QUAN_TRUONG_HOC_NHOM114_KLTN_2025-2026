@model demomvc.Models.GiaoVienVM
@{
    ViewBag.Title = "ChiTietGV";
    Layout = "~/Views/Shared/Tranhchu_LayoutPage1.cshtml";
}

<style>
    /* Card chứa toàn bộ thông tin */
    .gv-card {
        max-width: 850px;
        margin: 20px auto;
        background: #ffffff;
        border-radius: 10px;
        padding: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

        .gv-card h2 {
            text-align: center;
            font-size: 26px;
            margin-bottom: 20px;
            color: #0d6efd;
            font-weight: bold;
        }

    /* Bảng chi tiết */
    .gv-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 17px;
    }

        .gv-table th {
            width: 35%;
            background-color: #f0f4f8;
            padding: 10px;
            text-align: left;
            font-weight: bold;
            color: #333;
        }

        .gv-table td {
            padding: 10px;
            background-color: #fff;
            color: #222;
        }

        /* Màu xen kẽ */
        .gv-table tr:nth-child(odd) td {
            background-color: #f9fbfc;
        }

        /* Hiệu ứng hover */
        .gv-table tr:hover td {
            background: #e7f3ff;
            transition: 0.2s;
        }

    /* Nút quay lại */
    .btn-back {
        display: inline-block;
        margin-top: 20px;
        padding: 10px 18px;
        background: #0d6efd;
        color: white !important;
        border-radius: 6px;
        text-decoration: none;
        font-size: 16px;
    }

        .btn-back:hover {
            background: #084298;
        }


    @@media (max-width: 768px) {
        .gv-card {
            padding: 15px;
        }

        .gv-table th, .gv-table td {
            font-size: 15px;
            display: block;
            width: 100%;
        }

        .gv-table tr {
            margin-bottom: 12px;
            display: block;
            border-bottom: 1px solid #ddd;
        }

        .gv-table th {
            background: none;
            font-size: 14px;
            color: #555;
            padding-bottom: 3px;
        }

        .gv-table td {
            background: #fff;
            padding-top: 0px;
        }
    }
</style>


<div class="gv-card">
    <h2>Thông tin chi tiết giáo viên</h2>

    <table class="gv-table">
        <tr>
            <th>Mã giáo viên</th>
            <td>@Model.GiaoVienID</td>
        </tr>
        <tr>
            <th>Họ tên</th>
            <td>@Model.HoTen</td>
        </tr>
        <tr>
            <th>Giới tính</th>
            <td>@Model.GioiTinh</td>
        </tr>
        <tr>
            <th>Ngày sinh</th>
            <td>@(Model.NgaySinh.HasValue ? Model.NgaySinh.Value.ToString("dd/MM/yyyy") : "—")</td>
        </tr>
        <tr>
            <th>Môn giảng dạy</th>
            <td>@Model.TenMonHoc</td>
        </tr>
        <tr>
            <th>Tổ bộ môn</th>
            <td>@Model.TenBoMon</td>
        </tr>
        <tr>
            <th>Trạng thái giảng dạy</th>
            <td>@Model.TrangThaiGiangDay</td>
        </tr>
        <tr>
            <th>Lớp chủ nhiệm</th>
            <td>@Model.LopChuNhiem</td>
        </tr>
        <tr>
            <th>Email</th>
            <td>@Model.Email</td>
        </tr>
        <tr>
            <th>Số điện thoại</th>
            <td>@Model.SDT</td>
        </tr>
        <tr>
            <th>Trạng thái tài khoản</th>
            <td>@Model.TrangThaiTK</td>
        </tr>
        <tr>
            <th>Vai trò</th>
            <td>@converRole(Model.VaiTro)</td>
        </tr>
    </table>

    <a href="@Url.Action("Index","QuanLyGiaoVien")" class="btn-back">← Quay lại</a>
</div>

    @functions{
        public string converRole(string role)
        {
            switch (role)
            {
                case "GiaoVien":
                    return "Giáo Viên";
                case "HieuTruong":
                    return "Hiệu Trưởng";
                case "BiThu":
                    return "Bí Thư";
                case "HieuPho":
                    return "Hiệu Phó";
                default:
                    return role;
            }
        }
        }



