@model demomvc.Models.PhongHocViewModel
@{
    ViewBag.Title = "CapNhatPhong";
    Layout = "~/Views/Shared/Tranhchu_LayoutPage1.cshtml";
}
<link href="~/css/updatePhong.css" rel="stylesheet" />


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<!-- JS -->
<script src="~/Scripts/jquery-3.7.0.js"></script>
<script src="~/Scripts/jquery.validate.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.js"></script>
<h2 class="mb-3">Cập nhật phòng học</h2>

<form action="/QuanLyPhongHoc/CapNhatPhong" method="post">
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.PhongHocID)

    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="row">

        <!-- Tên phòng -->
        <div class="col-md-6">
            <label>Tên phòng</label>
            @Html.TextBoxFor(m => m.TenPhong, new { @class = "form-control", required = "required" })
            @Html.ValidationMessageFor(m => m.TenPhong, "", new { @class = "text-danger" })
        </div>

        <!-- Số lượng chỗ ngồi -->
        <div class="col-md-6">
            <label>Số lượng chỗ ngồi</label>
            @Html.TextBoxFor(m => m.SoLuongChoNgoi, new
            {
                @class = "form-control",
                type = "number",
                min = "1",
                required = "required",
                oninvalid = "this.setCustomValidity('Số lượng phải > 0')",
                oninput = "this.setCustomValidity('')"
            })
            @Html.ValidationMessageFor(m => m.SoLuongChoNgoi, "", new { @class = "text-danger" })
        </div>

    </div>

    <div class="row mt-3">

        <!-- Loại phòng -->
        <div class="col-md-6">
            <label>Loại phòng</label>
            @Html.DropDownListFor(m => m.LoaiPhong,
                new SelectList(new[] {
                    new { Value = "Lý thuyết", Text = "Lý thuyết" },
                    new { Value = "Thực hành", Text = "Thực hành" },
                    new { Value = "Đa chức năng", Text = "Đa chức năng" }
                }, "Value", "Text", Model.LoaiPhong),
                "-- Chọn loại phòng --",
                new { @class = "form-control", required = "required" })
            @Html.ValidationMessageFor(m => m.LoaiPhong, "", new { @class = "text-danger" })
        </div>

        <!-- Trạng thái -->
        <div class="col-md-6">
            <label>Trạng thái</label>
            @Html.DropDownListFor(m => m.TrangThai,
                new SelectList(new[] {
                    new { Value = "Hoạt động", Text = "Hoạt động" },
                    new { Value = "Sửa chữa", Text = "Sửa chữa" }
                }, "Value", "Text", Model.TrangThai),
                "-- Chọn trạng thái --",
                new { @class = "form-control", required = "required" })
            @Html.ValidationMessageFor(m => m.TrangThai, "", new { @class = "text-danger" })
        </div>

    </div>

    <!-- Nút -->
    <!-- Nút ở giữa -->
    <div class="button-center">
        <button type="submit" class="btn btn-primary me-3">Lưu</button>
        <a href="@Url.Action("Index", "QuanLyPhongHoc")" class="btn btn-secondary">Hủy</a>
    </div>

</form>
