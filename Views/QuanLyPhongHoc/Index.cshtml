@model List<demomvc.Models.PhongHocViewModel>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/Tranhchu_LayoutPage1.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
<link href="~/css/updateelete.css" rel="stylesheet" />


<link href="~/css/thongbao.css" rel="stylesheet" />
<!-- JS -->
<script src="~/Scripts/jquery-3.7.0.js"></script>
<script src="~/Scripts/jquery.validate.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.js"></script>
<style>

    .top-action {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
        margin-top: 10px;
    }

        .top-action .btn {
            font-size: 14px;
            padding: 6px 14px;
            border-radius: 6px;
            font-weight: 600;
        }

        .top-action .btn-primary {
            background: #2f5f73;
            border: none;
        }

            .top-action .btn-primary:hover {
                background: #1e4353;
            }
    /* Link trong bảng */
    table a {
        text-decoration: none;
        color: black;
        font-weight: 600;
    }

        table a:hover {
            color: #c10000;
        }

    /* Header cố định */
    .table thead th {
        position: sticky;
        top: 0;
        background-color: #2f5f73 !important;
        color: white;
        z-index: 5;
        border-bottom: 2px solid #dee2e6;
    }

    /* Màu xen kẽ */
    .table tbody tr:nth-child(odd) {
        background-color: #f9f9f9;
    }

    .table tbody tr:nth-child(even) {
        background-color: #ffffff;
    }

    /* Hover */
    .table tbody tr:hover {
        background-color: #e6f2ff;
        transition: 0.2s;
    }

    .title-center {
        text-align: center;
        margin: 20px 0;
        font-weight: 700;
        color: #2f5f73;
    }


    h2.text-center {
        text-align: center;
        margin-top: 10px;
        font-weight: 700;
        color: #2f5f73;
    }

    .search-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 12px;
        margin: 20px auto;
        max-width: 850px;
    }

        .search-container select,
        .search-container input {
            height: 42px;
            border-radius: 8px;
            border: 1px solid #c8c8c8;
            padding: 6px 12px;
            font-size: 15px;
        }

        .search-container select {
            width: 180px;
        }

        .search-container input {
            flex: 1;
        }

    .btn-search {
        height: 42px;
        padding: 0 22px;
        border-radius: 8px;
        border: none;
        background-color: #2f5f73;
        color: white;
        font-weight: 600;
        font-size: 15px;
    }

        .btn-search:hover {
            background-color: #1e4353;
            color: #fff;
            cursor: pointer;
        }
</style>
<div class="container-fluid">
    <div id="toast" class="toast-message"></div>
    <script>
     function showToast(message, isError = false) {
         var toast = document.getElementById("toast");
         toast.innerHTML = message;

         if (isError) {
             toast.classList.add("toast-error");
         } else {
             toast.classList.remove("toast-error");
         }

         toast.classList.add("toast-show");

         setTimeout(function () {
             toast.classList.remove("toast-show");
         }, 3000);
     }
     @if (TempData["Success"] != null)
 {
     <text>showToast('@TempData["Success"]', false);</text>
 }
 @if (TempData["Error"] != null)
 {
     <text>showToast('@TempData["Error"]', true);</text>
 }
    </script>

    <div class="top-action">
        <a href="@Url.Action("ThemMoiPhong", "QuanLyPhongHoc")" class="btn btn-primary">
            + Thêm Mới phòng học
        </a>
    </div>

    <h2 class="title-center">Danh sách phòng học</h2>


    <div class="search-container">


        <input id="searchInput" type="search" class="form-control"
               placeholder="Nhập tên phòng" value="@ViewBag.Keyword" />

        <button class="btn-search" onclick="searchGV()">Tìm kiếm</button>
    </div>



    <table class="table">
        <thead>
            <tr>
                <th>Mã phòng</th>
                <th>Tên phòng</th>
                <th>Số lượng chỗ ngồi</th>
                <th>Loại phòng</th>
                <th>Trạng thái</th>
                <th></th>

            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.PhongHocID</td>
                    <td>@item.TenPhong</td>
                    <td>@item.SoLuongChoNgoi</td>
                    <td>
                        @item.LoaiPhong
                    </td>
                    <td>@item.TrangThai</td>
                    <td class="action-cell">
                        <a href="/QuanLyPhongHoc/CapNhatPhong/@item.PhongHocID"
                           class="action-btn edit-btn">
                            <i class="fa fa-pen"></i> Cập nhật
                        </a>


                        @using (Html.BeginForm("Delete", "QuanLyPhongHoc", FormMethod.Post, new { onsubmit = "return confirmDelete(this);" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.Hidden("id", item.PhongHocID)
                            <button type="submit" class="action-btn delete-btn" title="Xóa">
                                <i class="fa fa-trash"></i> Xóa
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
    <script>
        function searchGV() {
            var keyword = document.getElementById("searchInput").value;
            window.location.href = '/QuanLyPhongHoc/Index?keyword=' + encodeURIComponent(keyword);
        }
        function confirmDelete() {
            return confirm("Bạn có chắc muốn xóa phòng học này? ");
        }
    </script>

