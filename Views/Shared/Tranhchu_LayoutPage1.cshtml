<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <link href="~/css/menuchu.css" rel="stylesheet" />
    <script src="~/Scripts/jquery-3.4.1.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
    <script src="~/Scripts/popper.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>


    <style>
        /* Khung vuông chuẩn, vừa khung, giữ tỉ lệ */
        .avatar-square {
            width: 40px; /* chiều ngang */
            height: 40px; /* chiều dọc */
            object-fit: cover; /* cắt vừa khung, không méo */
            border: 2px solid #fff; /* viền trắng */
            border-radius: 6px; /* bo nhẹ các góc, nếu muốn vuông tuyệt đối để 0 */
        }

        .thongbao-wrapper {
            position: relative;
            margin-right: 12px;
        }

        .thongbao-badge {
            position: absolute;
            top: -6px;
            right: -6px;
            min-width: 18px;
            height: 18px;
            padding: 0 5px;
            background-color: red;
            color: white;
            font-size: 11px;
            font-weight: bold;
            border-radius: 50%;
            display: none;
            text-align: center;
            line-height: 18px;
        }
    </style>

</head>
<body>
    @*menu*@
    @{
        string vaiTro = Session["VaiTro"]?.ToString();
    }

    <nav class="navbar navbar-expand-sm bg-success navbar-dark ">
        <a class="navbar-brand " href="@Url.Action("Index", "Trangchu")">
            <img src="@Url.Content("~/img/logo1.png")" alt="logo" width="120" height="40" class="logo-img" />
        </a>
        <div class="">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Trangchu")" class="nav-link  @(ViewContext.RouteData.Values["controller"].ToString() == "Trangchu" ? "active" : "")">Trang chủ</a>
                </li>

                @if (vaiTro == "HocSinh")
                {
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "XemDiem")" class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "XemDiem" ? "active" : "")">Xem điểm</a>
                    </li>

                    <li class="nav-item">
                        <a href="#" class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "" ? "active" : "")">Xem thời khóa biểu</a>
                    </li>

                }
                @if (vaiTro == "GiaoVien" || vaiTro == "HieuPho" || vaiTro == "BiThu")
                {
                    <li class="nav-item">
                        <a href="#" class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "" ? "active" : "")">Quản lý điểm</a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "" ? "active" : "")">Xem thời khóa biểu</a>
                    </li>
                }

                @if (vaiTro == "HieuTruong")
                {
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "QuanLyLopHoc")" class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "QuanLyLopHoc" ? "active" : "")">Quản lý lớp học</a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "QuanLyPhongHoc")" class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "QuanLyPhongHoc" ? "active" : "")">Quản lý phòng học</a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "QuanLyGiaoVien")" class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "QuanLyGiaoVien" ? "active" : "")">Quản lý giáo viên</a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "QuanLyHocSinh" ? "active" : "")">Quản lý học sinh</a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "QuanLyThoiKhoaBieu")" class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "QuanLyThoiKhoaBieu" ? "active" : "")">Quản lý thời khóa biểu</a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "" ? "active" : "")">Quản lý điểm</a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "" ? "active" : "")">Xem thời khóa biểu</a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "QuanLyThongBao")" class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "QuanLyThongBao" ? "active" : "")">Thông báo</a>
                    </li>

                }

            </ul>
        </div>
        @{

            string thongtinUrl;
            if (vaiTro == "HocSinh")
            {
                thongtinUrl = Url.Action("Index", "ThongTinHocSinh");
            }
            else if (vaiTro == "GiaoVien" || vaiTro == "HieuTruong" || vaiTro == "HieuPho" || vaiTro == "BiThu")
            {
                thongtinUrl = Url.Action("Index", "ThongTinGiaoVien");
            }
            else
            {
                thongtinUrl = "#"; // Vai trò khác hoặc chưa đăng nhập
            }
        }

        @*Anh avata*@

        <div class="d-flex align-items-center ml-auto pr-3">

            <div class="thongbao-wrapper">
                <a href="@Url.Action("ThongBaoNguoiDung", "DemThongBao")"
                   class="text-white"
                   id="iconThongBao">
                    <i class="bi bi-bell-fill fs-4"></i>

                    <!-- SỐ THÔNG BÁO -->
                    <span id="badgeThongBao" class="thongbao-badge">0</span>
                </a>
            </div>


            <div class="opdown m-0 p-0">
                <a href="#" class="dropdown-toggle p-0" id="userDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <img src="@(Session["AvatarUrl"] ?? Url.Content("~/img/imgUser.png"))"
                         class="avatar-square"
                         alt="Avatar" />
                </a>
                <div class="dropdown-menu dropdown-menu-right" aria-labelledby="userDropdown">
                    @if (Session["UserName"] != null)
                    {
                        <span class="dropdown-item font-weight-bold">
                            @Session["HoTen"]
                        </span>

                        <a class="dropdown-item" href="@thongtinUrl">Thông tin cá nhân</a>
                        <a class="dropdown-item" href="@Url.Action("Index", "DoiMatKhau")">Đổi mật khẩu</a>

                        @* Chỉ GIÁO VIÊN & HIỆU TRƯỞNG mới thấy *@
                        if (Session["VaiTro"] != null &&
                            (Session["VaiTro"].ToString() == "GiaoVien"
                          || Session["VaiTro"].ToString() == "HieuTruong"))
                        {
                            <a class="dropdown-item" href="@Url.Action("Index", "GuiBanDiem")">
                                Gửi bản điểm
                            </a>
                        }

                        <a class="dropdown-item" href="@Url.Action("Logout", "DangNhap")">
                            Đăng xuất
                        </a>
                    }
                    else
                    {
                        <a class="dropdown-item" href="@Url.Action("Index", "DangNhap")">
                            Đăng nhập
                        </a>
                    }
                </div>
            </div>
        </div>

    </nav>
    <div class="container-fluid">
        @RenderBody()
    </div>
    <footer class="school-footer text-white">
        <div class="footer-overlay"></div>

        <div class="container py-5 position-relative">
            <div class="text-center mb-4">
                <img src="~/img/logo1.png" alt="Logo" style="height:70px;">
                <h2 class="mt-3 font-weight-bold">TRƯỜNG TRUNG HỌC CƠ SỞ AT10</h2>


            </div>

            <div class="row mt-5">
                <!-- LIÊN HỆ -->
                <div class="col-lg-3 col-md-6 mb-4 footer-contact">
                    <h5 class="footer-title">LIÊN HỆ</h5>
                    <p>
                        <img src="~/img/diachiicon.jpg" class="contact-icon" />
                        123 Phan Chu Trinh, Phú Xuân, TP Huế
                    </p>

                    <p>
                        <img src="~/img/callicon.png" class="contact-icon" />
                        0123.456.789
                    </p>

                    <p>
                        <img src="~/img/emailicon.png" class="contact-icon" />
                        thcs123@school.edu.vn
                    </p>

                </div>

                <!-- HỖ TRỢ -->
                <div class="col-lg-3 col-md-6 mb-4">
                    <h5 class="footer-title">HỖ TRỢ HỌC SINH</h5>
                    <ul class="footer-list">
                        <li><a href="#">Thông báo mới nhất</a></li>
                        <li><a href="#">Hướng dẫn tuyển sinh</a></li>
                        <li><a href="#">Lịch học – Lịch thi</a></li>
                        <li><a href="#">Liên hệ giáo viên chủ nhiệm</a></li>
                    </ul>
                </div>

                <!-- LIÊN KẾT NHANH -->
                <div class="col-lg-3 col-md-6 mb-4">
                    <h5 class="footer-title">LIÊN KẾT NHANH</h5>
                    <ul class="footer-list">
                        <li><a href="#">Trang chủ</a></li>
                        <li><a href="#">Giới thiệu</a></li>
                        <li><a href="#">Hoạt động – Sự kiện</a></li>
                        <li><a href="#">Thư viện ảnh</a></li>
                    </ul>
                </div>

                <!-- GALLERY -->
                <div class="col-lg-3 col-md-6 mb-4">
                    <h5 class="footer-title">GALLERY</h5>
                    <div class="row g-2">
                        <div class="col-4"><img src="~/img/hocsinh1.jpg" class="gallery-img"></div>
                        <div class="col-4"><img src="~/img/hocsinh2.jpg" class="gallery-img"></div>
                        <div class="col-4"><img src="~/img/hocsinh3.jpg" class="gallery-img"></div>

                        <div class="col-4"><img src="~/img/hocsinh4.jpg" class="gallery-img"></div>
                        <div class="col-4"><img src="~/img/anhtrai.jpg" class="gallery-img"></div>
                        <div class="col-4"><img src="~/img/anhpahi.jpg" class="gallery-img"></div>
                    </div>
                </div>
            </div>

            <!-- ICON CUỐI TRANG -->
            <div class="social-icons-footer mt-5">
                <a href="#"><img src="~/img/ficon.png" class="social-icon-img" /></a>
                <a href="#"><img src="~/img/igicon.png" class="social-icon-img" /></a>
                <a href="#"><img src="~/img/youtobeicon.png" class="social-icon-img" /></a>
                <a href="#"><img src="~/img/chimicon.png" class="social-icon-img" /></a>
            </div>

        </div>
    </footer>
    <script>
    $(document).ready(function () {
        loadThongBao();
    });

    function loadThongBao() {
        $.ajax({
            url: '@Url.Action("DemThongBaoChuaDoc", "DemThongBao")',
            type: 'GET',
            success: function (count) {
                if (count > 0) {
                    $('#badgeThongBao').text(count).show();
                } else {
                    $('#badgeThongBao').hide();
                }
            },
            error: function () {
                console.log("Không load được thông báo");
            }
        });
    }
    </script>

</body>
</html>
