@{
    ViewBag.Title = "Cập nhật ảnh đại diện";
    Layout = "~/Views/Shared/Tranhchu_LayoutPage1.cshtml";
}
<!-- CSS -->
<link href="~/css/thongtinhocsinh.css" rel="stylesheet" />
<link href="~/css/thongbao.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<!-- JS -->
<script src="~/Scripts/jquery-3.7.0.js"></script>
<script src="~/Scripts/jquery.validate.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.js"></script>
<h3 class="text-center mt-4">Cập nhật ảnh đại diện</h3>
<div id="toast" class="toast-message"></div>
<script>
     function showToast(message, isError = false) {
         var toast = document.getElementById("toast");
         toast.innerHTML = message;

         if (isError) {
             toast.classList.add("toast-error");
         } else {
             toast.classList.remove("toast-error");
         }

         toast.classList.add("toast-show");

         setTimeout(function () {
             toast.classList.remove("toast-show");
         }, 3000);
     }
     @if (TempData["Success"] != null)
 {
     <text>showToast('@TempData["Success"]', false);</text>
 }
 @if (TempData["Error"] != null)
 {
     <text>showToast('@TempData["Error"]', true);</text>
 }
</script>
<form method="post" enctype="multipart/form-data" class="mt-3 text-center">

    <!-- Ảnh xem trước / click để chọn ảnh -->
    <label for="AvatarFile" style="cursor: pointer; display: inline-block;">
        <img id="previewImage"
             src="@(!string.IsNullOrEmpty(Model?.NguoiDung?.AnhDaiDien)
                     ? Url.Content(Model.NguoiDung.AnhDaiDien)
                     : Url.Content("~/img/imgUser.png"))"
             style="width: 180px; height: 220px; object-fit: cover;
                    border-radius: 12px; border: 3px solid #198754;"
             title="Click để chọn ảnh" />
        <div style="margin-top: 8px; font-weight: bold; color: #198754;">
            Chọn ảnh mới
        </div>
    </label>

    <!-- input file thật bị ẩn -->
    <input type="file" id="AvatarFile" name="AvatarFile" accept="image/*"
           style="display: none;" onchange="previewAvatar(event)" />

    <div class="mt-3">
        <button type="submit" class="btn btn-success">Lưu ảnh</button>
        <a href="/ThongTinHocSinh/Index" class="btn btn-secondary">Hủy</a>
    </div>
</form>

<script>
    function previewAvatar(event) {
        const img = document.getElementById('previewImage');
        if (event.target.files && event.target.files[0]) {
            img.src = URL.createObjectURL(event.target.files[0]);
        }
    }
</script>
